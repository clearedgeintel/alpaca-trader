# Alpaca (paper trading)
ALPACA_API_KEY=your_alpaca_key
ALPACA_API_SECRET=your_alpaca_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# Supabase Postgres (direct connection)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# App
PORT=3001
NODE_ENV=development

# Agency mode
USE_AGENCY=false
ANTHROPIC_API_KEY=your_anthropic_key

# API security (optional — auth skipped if not set)
# API_KEY=your_random_32char_hex

# LLM guardrails
LLM_DAILY_COST_CAP_USD=5.00
LLM_DAILY_TOKEN_CAP=500000
LLM_CIRCUIT_BREAKER_FAILURES=3

# Risk management (optional overrides)
# MAX_DRAWDOWN_PCT=0.10
# CORRELATION_THRESHOLD=0.85

# Alerts (optional)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...
