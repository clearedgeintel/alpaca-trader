{
  "name": "alpaca-trader",
  "version": "1.0.0",
  "description": "Alpaca paper trading bot with momentum strategy (EMA + RSI + Volume)",
  "main": "src/index.js",
  "scripts": {
    "build": "cd trader-ui && npm install && npm run build",
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "dev:ui": "cd trader-ui && npm run dev",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "lint": "echo 'No linter configured'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@tensorflow/tfjs": "^4.22.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^8.3.2",
    "luxon": "^3.4.0",
    "pg": "^8.11.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  }
}
