{
  "name": "alpaca-trader",
  "version": "1.0.0",
  "description": "Alpaca paper trading bot with momentum strategy (EMA + RSI + Volume)",
  "main": "src/index.js",
  "scripts": {
    "build": "cd trader-ui && npm install && npm run build",
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "dev:ui": "cd trader-ui && npm run dev",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:integration": "jest --forceExit --detectOpenHandles tests/integration",
    "test:coverage": "jest --coverage --forceExit",
    "lint": "eslint \"src/**/*.js\" \"tests/**/*.js\"",
    "lint:fix": "eslint \"src/**/*.js\" \"tests/**/*.js\" --fix",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@tensorflow/tfjs": "^4.22.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^8.3.2",
    "luxon": "^3.4.0",
    "pg": "^8.11.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.8.2",
    "supertest": "^7.2.2"
  }
}
